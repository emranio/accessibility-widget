{
  "name": "@firefam/react-accessibility-widget",
  "version": "0.2.5",
  "description": "A lightweight React accessibility widget with configurable accessibility profiles, visual adjustments, and reading tools.",
  "license": "MIT",
  "author": "firefam",
  "homepage": "https://github.com/firefam/react-accessibility-widget",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firefam/react-accessibility-widget.git"
  },
  "bugs": {
    "url": "https://github.com/firefam/react-accessibility-widget/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "widget",
    "react",
    "dyslexia",
    "contrast",
    "color-blind",
    "keyboard-navigation",
    "i18n",
    "rtl",
    "dark-mode"
  ],
  "main": "./dist/react.cjs.js",
  "module": "./dist/react.esm.js",
  "types": "./dist/react.d.ts",
  "exports": {
    ".": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.esm.js",
      "require": "./dist/react.cjs.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.esm.js",
      "require": "./dist/react.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "tsup",
    "build:demo": "vite build",
    "dev": "vite",
    "dev:lib": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist demo-dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "lucide-react": "^1.18.0"
  }
}
